func openShareStore(ctx context.Context) (*store.Store, error) {
	dbPath := defaultDBPath("{{.Name}}-pp-cli")
	s, err := store.OpenWithContext(ctx, dbPath)
	if err != nil {
		return nil, fmt.Errorf("open cache at %s: %w", dbPath, err)
